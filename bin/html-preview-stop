#!/usr/bin/env bash
set -euo pipefail

pid_file="/tmp/html-preview-serve-${USER}.pid"
state_file="/tmp/html-preview-serve-${USER}.dir"

if [[ ! -f "${pid_file}" ]]; then
  echo "Not running (no pid file)."
  rm -f "${state_file}"
  exit 0
fi

pid="$(cat "${pid_file}" 2>/dev/null || true)"

if [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null; then
  kill "${pid}"
  echo "Stopped html preview server (pid=${pid})."
else
  echo "Not running (stale pid=${pid})."
fi

rm -f "${pid_file}" "${state_file}"
