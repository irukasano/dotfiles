#!/usr/bin/env bash
set -euo pipefail

# Usage:
#   html-preview-serve [dir] [port]
#
# Behavior:
#   - Runs in background
#   - Logs to /tmp/html-preview-serve.log (append)
#   - PID file: /tmp/html-preview-serve-$USER.pid
#   - State file: /tmp/html-preview-serve-$USER.dir

target_dir="${1:-.}"
port="${2:-8080}"
log_file="/tmp/html-preview-serve.log"
pid_file="/tmp/html-preview-serve-${USER}.pid"
state_file="/tmp/html-preview-serve-${USER}.dir"
script_dir="$(pwd)"

is_running() {
  local pid="$1"
  [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null
}

target_dir="$(cd "${target_dir}" && pwd)"

if [[ -f "${pid_file}" ]]; then
  old_pid="$(cat "${pid_file}" 2>/dev/null || true)"
  old_dir="$(cat "${state_file}" 2>/dev/null || true)"
  if is_running "${old_pid}"; then
    if [[ "${old_dir}" == "${target_dir}" ]]; then
      echo "Already running (pid=${old_pid})."
      echo "Serving dir: ${target_dir}"
      echo "URL:         http://localhost:${port}/"
      exit 0
    fi
    kill "${old_pid}"
  fi
  rm -f "${pid_file}" "${state_file}"
fi

cd "${target_dir}"
nohup python3 -m http.server "${port}" --bind 127.0.0.1 \
  >> "${log_file}" 2>&1 &
pid="$!"
cd "${script_dir}"

printf '%s\n' "${target_dir}" > "${state_file}"
printf '%s\n' "${pid}" > "${pid_file}"

echo "Started html preview server (pid=${pid})"
echo "Serving dir: ${target_dir}"
echo "Log:         ${log_file}"
echo "URL:         http://localhost:${port}/"
